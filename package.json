{
  "name": "tokaroo-openclaw-provider",
  "version": "0.1.0",
  "description": "Tokaroo provider plugin for OpenClaw.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://tokaroo.com/integrations/openclaw",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokaroo-ai/openclaw-provider.git"
  },
  "bugs": {
    "url": "https://github.com/tokaroo-ai/openclaw-provider/issues"
  },
  "keywords": [
    "tokaroo",
    "openclaw",
    "plugin",
    "provider",
    "llm"
  ],
  "files": [
    "index.ts",
    "openclaw.plugin.json",
    "src",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "providers": [
      "tokaroo"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.28",
      "pluginSdkVersion": "2026.3.28"
    }
  },
  "dependencies": {
    "openclaw": "2026.3.28"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
